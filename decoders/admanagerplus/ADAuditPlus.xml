<!-- Decoder base -->
<decoder name="admanagerplus_first">
    <program_name>ADAuditPlus</program_name>
</decoder>

<!-- User -->
<decoder name="admanager_child">
  <parent>admanagerplus_first</parent>
  <regex type="pcre2">User '([^']+)'</regex>
  <order>srcuser</order>
</decoder>

<!-- Rason -->
<decoder name="admanager_child">
    <parent>admanagerplus_first</parent>
    <regex type="pcre2">Reason: '([^']+)'</regex>
    <order>Veredito</order>
</decoder>

<!-- Origem -->
<decoder name="admanager_child">
    <parent>admanagerplus_first</parent>
    <regex type="pcre2">in '([^']+)'</regex>
    <order>srcip</order>
</decoder>

